{
  "name": "horizon-theme",
  "version": "0.0.1",
  "type": "module",
  "main": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./config": "./config.ts",
    "./components": "./components/*",
    "./style.scss": "./themes/style.scss",
    "./assets/*": "./assets/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "use:src": "node scripts/switch-mode.js src",
    "use:dist": "node scripts/switch-mode.js dist",
    "release": "npm run use:dist && cd dist && npm publish"
  },
  "peerDependencies": {
    "sass": "catalog:",
    "typescript": "catalog:",
    "vitepress": "catalog:",
    "vue": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "vite": "catalog:",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "@fancyapps/ui": "^6.1.13",
    "js-yaml": "^4.1.1"
  }
}
