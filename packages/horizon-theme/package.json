{
  "name": "@roidmc/horizon-theme",
  "version": "0.0.5",
  "type": "module",
  "main": "index.ts",
  "author": {
    "name": "chencu5958",
    "email": "hi@roidmc.com",
    "url": "https://github.com/chencu5958"
  },
  "exports": {
    ".": "./index.ts",
    "./config": "./config.ts",
    "./components": "./components/*",
    "./style.scss": "./themes/style.scss",
    "./assets/*": "./assets/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
