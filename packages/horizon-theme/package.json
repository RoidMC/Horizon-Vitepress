  },
  "dependencies": {
    "@fancyapps/ui": "^6.1.13",
    "acorn": "^8.16.0",
    "gray-matter": "4.0.3",
    "js-yaml": "^4.1.1",
    "magic-string": "^0.30.21"
  }
