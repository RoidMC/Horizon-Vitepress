    "release": "npm run build && cd dist && npm publish"
  },
  "peerDependencies": {
    "sass": "catalog:",
    "typescript": "catalog:",
    "vitepress": "catalog:",
    "vue": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "^6.0.5",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  },
  "dependencies": {
    "@11ty/gray-matter": "^2.0.1",
    "@fancyapps/ui": "^6.1.13",
    "@roidmc/horizon-pulse-core": "workspace:*",
    "yaml": "^2.8.3"
  }
}
